# Vault (PDF directory)
PDF_MCP_VAULT_PATH=~/Documents/PDFs
PDF_MCP_DB_PATH=~/.local/share/pdf-mcp/pdf.db

# Server
PDF_MCP_TRANSPORT=http
PDF_MCP_PORT=10201
PDF_MCP_LOG_LEVEL=INFO

# For reverse proxy (set MCP_PATH=/ when Caddy strips prefix)
# PDF_MCP_MCP_PATH=/

# OAuth (optional — copy from email/notes MCP, same GitHub app works)
# PDF_MCP_GITHUB_CLIENT_ID=
# PDF_MCP_GITHUB_CLIENT_SECRET=
# PDF_MCP_OAUTH_BASE_URL=https://your-domain/mcp/pdf
# PDF_MCP_OAUTH_ALLOWED_USERS=your-github-username
# PDF_MCP_OAUTH_STATE_DIR=~/.local/share/pdf-mcp/oauth
